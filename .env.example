# Use Postgres in production (Render injects this automatically)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/london_tasteful_events

# Admin authentication (recommended in production)
# If ADMIN_PASSWORD is set, all routes except /healthz require HTTP Basic Auth.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Auto-import orgs_bootstrap.json into an empty database on startup
AUTO_BOOTSTRAP_ORGS=true

# Discovery search backend:
# - duckduckgo (default)
# - openai_web (uses OpenAI Responses API + web_search tool)
DISCOVERY_SEARCH_PROVIDER=duckduckgo

# Required when DISCOVERY_SEARCH_PROVIDER=openai_web
OPENAI_API_KEY=
DISCOVERY_OPENAI_MODEL=gpt-5
DISCOVERY_OPENAI_EXTERNAL_WEB_ACCESS=true
DISCOVERY_OPENAI_FALLBACK_TO_DUCKDUCKGO=true

# Allow several URLs per domain before candidate extraction.
DISCOVERY_MAX_URLS_PER_DOMAIN=3
